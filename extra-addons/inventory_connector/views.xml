<record id="view_external_inventory_form" model="ir.ui.view">
    <field name="name">external.inventory.form</field>
    <field name="model">external.inventory</field>
    <field name="arch" type="xml">
        <form>
            <header>
                <button name="action_import_from_api" string="Импортировать данные" type="object" class="btn-primary"/>
            </header>
            <sheet>
                <group>
                    <field name="name"/>
                    <field name="api_token"/>
                </group>
                <group string="Aggregated Data (Read Only)">
                    <field name="oldest_item"/>
                    <field name="total_likes"/>
                    <field name="avg_likes"/>
                    <field name="top_contributor"/>
                </group>
            </sheet>
        </form>
    </field>
</record>